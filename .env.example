# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=strongpassword123
POSTGRES_DB=pdfmanager

# JWT
JWT_SECRET=replace_this_with_a_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=replace_this_with_another_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth (set up at https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost/api/auth/google/callback

# App
CLIENT_URL=http://localhost
NODE_ENV=production
